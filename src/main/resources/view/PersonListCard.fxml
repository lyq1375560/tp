<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="10" right="10" bottom="10" left="15" />
      </padding>
      <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
        <FlowPane fx:id="tags" hgap="5" />
      </HBox>
      <Label fx:id="products" styleClass="cell_small_label" text="\$products" wrapText="true" />
      <Label fx:id="locationValue" styleClass="cell_small_label" text="\$location" />
      <Label fx:id="deadline" styleClass="cell_small_label" text="\$deadline" />
      <Label fx:id="contact" styleClass="cell_small_label" text="\$contact" />
    </VBox>
  </GridPane>
</HBox>
